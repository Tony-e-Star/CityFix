# Firebase Service Account Credentials (JSON string of the service account service-account.json)
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", ...}

# Gemini API Key (Server-side secret used for civic categorization and descriptions)
GEMINI_API_KEY=your_gemini_api_key_here
