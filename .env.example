# Firebase Service Account Credentials (JSON string of the service account service-account.json)
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json_here

# Gemini API Key (Server-side secret used for civic categorization and descriptions)
GEMINI_API_KEY=your_gemini_api_key_here

# Client-side Firebase Configuration (Optional: can be set in Netlify / Vercel to override local defaults)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_FIRESTORE_DATABASE_ID=your_firestore_database_id_here
